        "footer": {
          "show": false
        }
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true,
              "service": true
            },
            "indexByName": {}
          }
        }
      ],
      "targets": [
        {
          "expr": "sum by (endpoint, method) (rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\"}[5m]))",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint, method) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint, method) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, endpoint, method) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "D",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (endpoint, method) (rate(axum_http_requests_duration_seconds_sum{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])) / clamp_min(sum by (endpoint, method) (rate(axum_http_requests_duration_seconds_count{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])), 0.0001)",
          "refId": "E",
          "format": "table",
          "instant": true
        }
      ],
      "description": "Per-endpoint table with RPS, p50/p95/p99 and avg latency over the last 5 minutes. Click the p95 column header to sort by slowest endpoint."
    },
