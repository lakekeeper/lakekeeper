  "id": null,
  "uid": "lakekeeper-overview",
  "title": "Lakekeeper Overview",
  "tags": [
    "lakekeeper",
    "iceberg"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(axum_http_requests_total, endpoint)",
          "refId": "Endpoints"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "label": "Endpoint",
        "sort": 1
      },
      {
        "name": "method",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(axum_http_requests_total, method)",
          "refId": "Methods"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "label": "Method",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 20,
      "title": "Up",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(up{job=\"lakekeeper\"})",
          "refId": "A"
        }
      ],
      "description": "Whether Prometheus is currently scraping Lakekeeper's /metrics endpoint. DOWN means the scrape failed (process gone, port unreachable, or metrics port not exposed) \u2014 not necessarily that the catalog is broken, but observability is."
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Requests / sec",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 3,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\"}[1m]))",
          "refId": "A",
          "legendFormat": "rps"
        }
      ],
      "description": "Total HTTP request rate across all endpoints, averaged over 1 minute. Affected by the endpoint and method filters at the top."
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Error rate (5xx)",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 7,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * (sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\",status=~\"5..\"}[5m])) or vector(0)) / clamp_min(sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])), 0.0001)",
          "refId": "A",
          "legendFormat": "5xx %"
        }
      ],
      "description": "Percentage of requests in the last 5 minutes that returned a 5xx server error. Sustained values above 1% indicate a real incident."
    },
    {
      "type": "stat",
      "id": 21,
      "title": "Apdex (T=0.25s)",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 11,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.94
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(\n  sum(rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\",le=\"0.25\"}[5m]))\n  + sum(rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\",le=\"1\"}[5m]))\n) / 2 / clamp_min(sum(rate(axum_http_requests_duration_seconds_count{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])), 0.0001)",
          "refId": "A",
          "legendFormat": "apdex"
        }
      ],
      "description": "Application Performance Index with a 250ms target. Score = (fast + tolerated/2) / total, where 'fast' = \u2264250ms and 'tolerated' = \u22641000ms. 1.0 means every request is fast; below 0.85 users will notice; below 0.7 users are unhappy."
    },
    {
      "type": "stat",
      "id": 3,
      "title": "p95 latency",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 15,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "A",
          "legendFormat": "p95"
        }
      ],
      "description": "95th-percentile request duration over the last 5 minutes. 95% of requests completed faster than this value."
    },
    {
      "type": "stat",
      "id": 4,
      "title": "In-flight",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 19,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(axum_http_requests_pending{endpoint=~\"$endpoint\",method=~\"$method\"})",
          "refId": "A",
          "legendFormat": "in-flight"
        }
      ],
      "description": "Number of HTTP requests currently being processed. Steady traffic with growing in-flight = backpressure (downstream is slow)."
    },
    {
      "type": "row",
      "id": 101,
      "title": "Requests",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Request rate by status class",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "2xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "3xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "4xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "5xx"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\",status=~\"2..\"}[1m]))",
          "refId": "A",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\",status=~\"3..\"}[1m]))",
          "refId": "B",
          "legendFormat": "3xx"
        },
        {
          "expr": "sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\",status=~\"4..\"}[1m]))",
          "refId": "C",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(axum_http_requests_total{endpoint=~\"$endpoint\",method=~\"$method\",status=~\"5..\"}[1m]))",
          "refId": "D",
          "legendFormat": "5xx"
        }
      ],
      "description": "RPS stacked by status class \u2014 2xx success (green), 3xx redirect, 4xx client error (yellow), 5xx server error (red). Stack height is total RPS; growing red slice = problems."
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Latency percentiles (overall)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])))",
          "refId": "C",
          "legendFormat": "p99"
        },
        {
          "expr": "sum(rate(axum_http_requests_duration_seconds_sum{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])) / clamp_min(sum(rate(axum_http_requests_duration_seconds_count{endpoint=~\"$endpoint\",method=~\"$method\"}[5m])), 0.0001)",
          "refId": "D",
          "legendFormat": "avg"
        }
      ],
      "description": "p50, p95, p99 and avg request latency. p50 \u2248 typical user; p99 \u2248 worst 1%. Diverging p50 vs p99 = tail-latency problem (most requests fine, a few very slow)."
    },
