          "refId": "A",
          "legendFormat": "{{method}}"
        }
      ],
      "description": "RPS broken down by HTTP method. Useful for separating reads (GET/HEAD) from writes (POST/PUT/DELETE)."
    },
    {
      "type": "heatmap",
      "id": 23,
      "title": "Latency heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "calculate": false,
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        },
        "color": {
          "scheme": "Spectral",
          "steps": 64,
          "mode": "scheme",
          "exponent": 0.5,
          "fill": "dark-orange"
        },
        "cellGap": 1,
        "filterValues": {
          "le": 1e-09
        },
        "tooltip": {
          "show": true,
          "yHistogram": true
        },
        "legend": {
          "show": true
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(axum_http_requests_duration_seconds_bucket{endpoint=~\"$endpoint\",method=~\"$method\"}[$__rate_interval]))",
          "refId": "A",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "description": "Distribution of request latencies over time. Each column = one time slice; each row = a latency bucket (e.g. 100\u2013250ms); color intensity = how many requests fell into that bucket during that slice. A single bright horizontal band = uniform latency. Two stacked bands = bimodal (e.g. cache-hit vs cache-miss). Reveals patterns p95/p99 lines hide."
    },
